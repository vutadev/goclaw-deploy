# GoClaw environment variables.
# Copy to .env and fill in values.
#
# Required: at least one LLM provider API key.

# --- LLM Provider (at least one required) ---
GOCLAW_OPENROUTER_API_KEY=
GOCLAW_ANTHROPIC_API_KEY=
GOCLAW_OPENAI_API_KEY=
GOCLAW_GEMINI_API_KEY=
GOCLAW_DEEPSEEK_API_KEY=
GOCLAW_MINIMAX_API_KEY=
GOCLAW_GROQ_API_KEY=
GOCLAW_MISTRAL_API_KEY=
GOCLAW_XAI_API_KEY=
GOCLAW_COHERE_API_KEY=
GOCLAW_PERPLEXITY_API_KEY=

# --- Gateway (required, generate random values) ---
# Generate with: openssl rand -hex 32
GOCLAW_GATEWAY_TOKEN=
GOCLAW_ENCRYPTION_KEY=

# --- Channels (optional) ---
GOCLAW_TELEGRAM_TOKEN=
GOCLAW_DISCORD_TOKEN=
GOCLAW_LARK_APP_ID=
GOCLAW_LARK_APP_SECRET=
GOCLAW_ZALO_TOKEN=

# --- Database (defaults work out of the box) ---
POSTGRES_PASSWORD=
# POSTGRES_USER=goclaw
# POSTGRES_DB=goclaw

# --- Domain & HTTPS (optional) ---
# Set GOCLAW_DOMAIN for auto HTTPS via Let's Encrypt.
# When set: Caddy serves HTTPS, redirects HTTP -> HTTPS.
# When empty: Caddy serves HTTP only (for behind-proxy or local dev).
# GOCLAW_DOMAIN=

# --- Host port mapping (optional, container listens on 8080/8443) ---
# GOCLAW_HTTP_PORT=80
# GOCLAW_HTTPS_PORT=443
# PGADMIN_PORT=5050

# --- pgAdmin (optional, included in all compose variants) ---
# PGADMIN_EMAIL=admin@admin.com
# PGADMIN_PASSWORD=admin

# --- Dokploy mode only (docker-compose-dokploy.yml) ---
# GOCLAW_DATA_VOLUME=goclaw-data
# GOCLAW_WORKSPACE_VOLUME=goclaw-workspace

# --- Build mode only (docker-compose-build.yml) ---
# GOCLAW_IMAGE=itsddvn/goclaw
# GOCLAW_VERSION=latest
